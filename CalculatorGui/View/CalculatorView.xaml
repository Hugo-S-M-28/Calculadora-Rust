<UserControl x:Class="CalculatorGui.View.CalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CalculatorGui.View"
             xmlns:gui="clr-namespace:CalculatorGui"
             xmlns:vm="clr-namespace:CalculatorGui.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="640">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <gui:ButtonTextConverter x:Key="ButtonTextConverter"/>
        <gui:StyleConverter x:Key="StyleConverter"/>
        <gui:ActivePropertyConverter x:Key="ActivePropertyConverter"/>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="640" Height="500">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Screen -->
            <Grid Grid.Row="0" Margin="10,15,10,5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- Notation Type -->
                <TextBlock Text="{Binding NotationType}" 
                           Foreground="{DynamicResource TextSecBrush}" 
                           FontSize="11" 
                           HorizontalAlignment="Left" 
                           VerticalAlignment="Top"
                           Margin="5,0,0,5"/>
                
                <!-- Expression Input -->
                <TextBox x:Name="TxtExpression" 
                         Grid.Row="1" 
                         Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                         Background="Transparent" 
                         BorderThickness="0" 
                         Foreground="{DynamicResource TextSecBrush}" 
                         FontSize="16" 
                         FontFamily="Segoe UI" 
                         TextAlignment="Right" 
                         VerticalAlignment="Center" 
                         CaretBrush="{DynamicResource SciButtonTextBrush}"
                         TextWrapping="Wrap"
                         AcceptsReturn="False"
                         GotFocus="TxtExpression_GotFocus"
                         PreviewKeyDown="TxtExpression_PreviewKeyDown"
                         Margin="0,0,0,5"/>

                <!-- Preview / Result Output -->
                <Viewbox Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" MaxHeight="70">
                    <TextBlock x:Name="TxtResult" 
                               Text="{Binding Result}" 
                               Opacity="{Binding PreviewOpacity}"
                               Foreground="{DynamicResource TextMainBrush}" 
                               FontSize="48" 
                               FontWeight="SemiBold" 
                               TextAlignment="Right" 
                               Margin="0,0,5,0"/>
                </Viewbox>
            </Grid>

            <!-- Row 1: DEG and Memory bar -->
            <Grid Grid.Row="1" Margin="10,2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- DEG and F-E toggles -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScientific}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Content="{Binding AngleModeText}" 
                            Command="{Binding ToggleAngleModeCommand}"
                            Style="{StaticResource FlatToggleButtonStyle}" 
                            Width="50" Height="28" Margin="0,0,5,0"/>
                    <Button Content="F-E" 
                            Style="{StaticResource FlatToggleButtonStyle}" 
                            Width="50" Height="28"/>
                </StackPanel>
                
                <!-- Memory Bar -->
                <UniformGrid Grid.Row="1" Columns="6" Height="28" Margin="0,0,0,2">
                    <Button Content="MC" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                    <Button Content="MR" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                    <Button Content="M+" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                    <Button Content="M-" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                    <Button Content="MS" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                    <Button Content="M▾" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                </UniformGrid>
            </Grid>

            <!-- Row 2: Menu dropdowns (Trigonometría, Función) -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10,2,10,5">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScientific}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <Button x:Name="BtnTrig" 
                        Content="  Trigonometría ▾" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="BtnTrig_Click"
                        Margin="0,0,10,0">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="sin" Click="MenuItem_Click"/>
                            <MenuItem Header="cos" Click="MenuItem_Click"/>
                            <MenuItem Header="tan" Click="MenuItem_Click"/>
                            <MenuItem Header="ctan" Click="MenuItem_Click"/>
                            <Separator/>
                            <MenuItem Header="asin" Click="MenuItem_Click"/>
                            <MenuItem Header="acos" Click="MenuItem_Click"/>
                            <MenuItem Header="atan" Click="MenuItem_Click"/>
                            <Separator/>
                            <MenuItem Header="sinh" Click="MenuItem_Click"/>
                            <MenuItem Header="cosh" Click="MenuItem_Click"/>
                            <MenuItem Header="tanh" Click="MenuItem_Click"/>
                            <Separator/>
                            <MenuItem Header="asinh" Click="MenuItem_Click"/>
                            <MenuItem Header="acosh" Click="MenuItem_Click"/>
                            <MenuItem Header="atanh" Click="MenuItem_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
                
                <Button x:Name="BtnFunc" 
                        Content="  Función ▾" 
                        Style="{StaticResource MenuButtonStyle}" 
                        Click="BtnFunc_Click">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="abs" Click="MenuItem_Click"/>
                            <MenuItem Header="floor" Click="MenuItem_Click"/>
                            <MenuItem Header="ceil" Click="MenuItem_Click"/>
                            <MenuItem Header="round" Click="MenuItem_Click"/>
                            <MenuItem Header="trunc" Click="MenuItem_Click"/>
                            <Separator/>
                            <MenuItem Header="min" Click="MenuItem_Click"/>
                            <MenuItem Header="max" Click="MenuItem_Click"/>
                            <MenuItem Header="mod" Click="MenuItem_Click"/>
                            <MenuItem Header="gcd" Click="MenuItem_Click"/>
                            <MenuItem Header="nCr" Click="MenuItem_Click"/>
                            <MenuItem Header="nPr" Click="MenuItem_Click"/>
                            <Separator/>
                            <MenuItem Header="x" Click="MenuItemVariable_Click"/>
                            <MenuItem Header="Resolver Ecuación" Click="MenuItemSolve_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>

            <!-- Row 3: Keypad Grid (Scientific: 5 columns, 7 rows) -->
            <ItemsControl ItemsSource="{Binding ScientificButtons}" Grid.Row="3" Margin="5,0,5,5">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScientific}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Grid.Row" Value="{Binding Row}"/>
                        <Setter Property="Grid.Column" Value="{Binding Column}"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ButtonInfo}">
                        <Button Click="CalculatorButton_Click" 
                                Style="{Binding StyleKey, Converter={StaticResource StyleConverter}}"
                                Command="{Binding Command}">
                            <Button.Content>
                                <MultiBinding Converter="{StaticResource ButtonTextConverter}">
                                    <Binding Path="NormalText"/>
                                    <Binding Path="ShiftText"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.IsSecondFunction"/>
                                </MultiBinding>
                            </Button.Content>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Row 3: Keypad Grid (Standard: 4 columns, 6 rows) -->
            <ItemsControl ItemsSource="{Binding StandardButtons}" Grid.Row="3" Margin="5,0,5,5">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScientific}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Grid.Row" Value="{Binding Row}"/>
                        <Setter Property="Grid.Column" Value="{Binding Column}"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ButtonInfo}">
                        <Button Click="CalculatorButton_Click" 
                                Style="{Binding StyleKey, Converter={StaticResource StyleConverter}}"
                                Command="{Binding Command}">
                            <Button.Content>
                                <MultiBinding Converter="{StaticResource ButtonTextConverter}">
                                    <Binding Path="NormalText"/>
                                    <Binding Path="ShiftText"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.IsSecondFunction"/>
                                </MultiBinding>
                            </Button.Content>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Viewbox>
</UserControl>
