<UserControl x:Class="CalculatorGui.View.CalculatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CalculatorGui.View"
             xmlns:gui="clr-namespace:CalculatorGui"
             xmlns:vm="clr-namespace:CalculatorGui.ViewModel"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="640">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        <gui:ButtonTextConverter x:Key="ButtonTextConverter"/>
        <gui:StyleConverter x:Key="StyleConverter"/>
        <gui:ActivePropertyConverter x:Key="ActivePropertyConverter"/>
    </UserControl.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Width="380" Height="600">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Screen (LCD glass container) -->
            <Border Grid.Row="0" 
                    Margin="10,15,10,10" 
                    Background="{DynamicResource ScreenBgBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1.5" 
                    CornerRadius="8" 
                    Padding="12,10,12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Status Bar -->
                        <RowDefinition Height="50"/>  <!-- Expression (Input/Overlay) -->
                        <RowDefinition Height="75"/>  <!-- Result Output -->
                    </Grid.RowDefinitions>

                    <!-- Top Status Bar: Notation Type & Angle Mode -->
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <TextBlock Text="{Binding NotationType}" 
                                   Foreground="{DynamicResource TextSecBrush}" 
                                   FontSize="11" 
                                   HorizontalAlignment="Left" 
                                   VerticalAlignment="Center"/>
                        
                        <TextBlock Text="{Binding AngleModeText}" 
                                   Foreground="{DynamicResource TextSecBrush}" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right" 
                                   VerticalAlignment="Center"
                                   Margin="0,0,5,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScientific}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <!-- Expression Row -->
                    <Grid Grid.Row="1" VerticalAlignment="Center">
                        <!-- Math Display Control (Natural formatting shown when not focused) -->
                        <local:MathDisplayControl ExpressionString="{Binding Expression}"
                                                 Foreground="{DynamicResource TextSecBrush}"
                                                 FontSize="16"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 IsHitTestVisible="False">
                            <local:MathDisplayControl.Style>
                                <Style TargetType="local:MathDisplayControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=TxtExpression, Path=IsFocused}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </local:MathDisplayControl.Style>
                        </local:MathDisplayControl>

                        <!-- Input TextBox (Standard text editing shown when focused) -->
                        <TextBox x:Name="TxtExpression" 
                                 Text="{Binding Expression, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 Foreground="{DynamicResource TextSecBrush}" 
                                 FontSize="16" 
                                 FontFamily="Segoe UI" 
                                 TextAlignment="Right" 
                                 VerticalAlignment="Center" 
                                 CaretBrush="{DynamicResource SciButtonTextBrush}"
                                 TextWrapping="NoWrap"
                                 AcceptsReturn="False"
                                 GotFocus="TxtExpression_GotFocus"
                                 PreviewKeyDown="TxtExpression_PreviewKeyDown">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsFocused" Value="True">
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                        <DataTrigger Binding="{Binding Expression}" Value="">
                                            <Setter Property="Opacity" Value="0.6"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>

                    <!-- Result Row -->
                    <Viewbox Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" MaxHeight="70">
                        <local:MathDisplayControl x:Name="TxtResult" 
                                                 ExpressionString="{Binding Result}" 
                                                 Opacity="{Binding PreviewOpacity}"
                                                 Foreground="{DynamicResource TextMainBrush}" 
                                                 FontSize="44" 
                                                 FontWeight="SemiBold"/>
                    </Viewbox>
                </Grid>
            </Border>

            <!-- Row 1: DEG and Memory bar -->
            <Grid Grid.Row="1" Margin="10,2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- DEG and F-E toggles -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,5">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsScientific}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Content="{Binding AngleModeText}" 
                            Command="{Binding ToggleAngleModeCommand}"
                            Style="{StaticResource FlatToggleButtonStyle}" 
                            Width="50" Height="28" Margin="0,0,5,0"/>
                    <Button Content="F-E" 
                            Style="{StaticResource FlatToggleButtonStyle}" 
                            Width="50" Height="28"/>
                </StackPanel>
                
                <!-- Memory Bar -->
                <UniformGrid Grid.Row="1" Columns="6" Height="28" Margin="0,0,0,2">
                    <Button Content="MC" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                    <Button Content="MR" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                    <Button Content="M+" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                    <Button Content="M-" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                    <Button Content="MS" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                    <Button Content="M▾" Style="{StaticResource MemoryButtonStyle}" IsEnabled="False"/>
                </UniformGrid>
            </Grid>

            <!-- Row 2: Menu dropdowns (Trigonometría, Función) -->
            <Grid Grid.Row="2" Margin="10,2,10,5">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScientific}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="BtnTrig" 
                            Content="  Trigonometría ▾" 
                            Style="{StaticResource MenuButtonStyle}" 
                            Click="BtnTrig_Click"
                            Margin="0,0,10,0"/>
                    
                    <Button x:Name="BtnFunc" 
                            Content="  Función ▾" 
                            Style="{StaticResource MenuButtonStyle}" 
                            Click="BtnFunc_Click"/>
                </StackPanel>

                <!-- Popups for Trig and Func -->
                <Popup x:Name="PopupTrig" 
                       PlacementTarget="{Binding ElementName=BtnTrig}" 
                       Placement="Bottom" 
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource WindowBgBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1.5" 
                            CornerRadius="8" 
                            Padding="6"
                            Width="250">
                        <UniformGrid Columns="4">
                            <Button Content="sin" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="cos" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="tan" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="ctan" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="asin" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="acos" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="atan" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="sinh" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="cosh" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="tanh" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="asinh" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="acosh" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            <Button Content="atanh" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                        </UniformGrid>
                    </Border>
                </Popup>

                <Popup x:Name="PopupFunc" 
                       PlacementTarget="{Binding ElementName=BtnFunc}" 
                       Placement="Bottom" 
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource WindowBgBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1.5" 
                            CornerRadius="8" 
                            Padding="6"
                            Width="250">
                        <StackPanel>
                            <UniformGrid Columns="4">
                                <Button Content="abs" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="floor" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="ceil" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="round" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="trunc" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="min" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="max" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="mod" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="gcd" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="nCr" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="nPr" Click="PopupButton_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                                <Button Content="x" Click="PopupButtonVariable_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                            </UniformGrid>
                            <Button Content="Resolver Ecuación" Click="PopupButtonSolve_Click" Style="{StaticResource PopupButtonStyle}" Margin="2" Height="36" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </Popup>
            </Grid>

            <!-- Row 3: Keypad Grid (Scientific: 5 columns, 7 rows) -->
            <ItemsControl ItemsSource="{Binding ScientificButtons}" Grid.Row="3" Margin="5,0,5,5">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScientific}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Grid.Row" Value="{Binding Row}"/>
                        <Setter Property="Grid.Column" Value="{Binding Column}"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ButtonInfo}">
                        <Button Click="CalculatorButton_Click" 
                                Style="{Binding StyleKey, Converter={StaticResource StyleConverter}}"
                                Command="{Binding Command}">
                            <Button.Content>
                                <MultiBinding Converter="{StaticResource ButtonTextConverter}">
                                    <Binding Path="NormalText"/>
                                    <Binding Path="ShiftText"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.IsSecondFunction"/>
                                </MultiBinding>
                            </Button.Content>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Row 3: Keypad Grid (Standard: 4 columns, 6 rows) -->
            <ItemsControl ItemsSource="{Binding StandardButtons}" Grid.Row="3" Margin="5,0,5,5">
                <ItemsControl.Style>
                    <Style TargetType="ItemsControl">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsScientific}" Value="False">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ItemsControl.Style>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                        </Grid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Grid.Row" Value="{Binding Row}"/>
                        <Setter Property="Grid.Column" Value="{Binding Column}"/>
                        <Setter Property="HorizontalAlignment" Value="Stretch"/>
                        <Setter Property="VerticalAlignment" Value="Stretch"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ButtonInfo}">
                        <Button Click="CalculatorButton_Click" 
                                Style="{Binding StyleKey, Converter={StaticResource StyleConverter}}"
                                Command="{Binding Command}">
                            <Button.Content>
                                <MultiBinding Converter="{StaticResource ButtonTextConverter}">
                                    <Binding Path="NormalText"/>
                                    <Binding Path="ShiftText"/>
                                    <Binding RelativeSource="{RelativeSource AncestorType=UserControl}" Path="DataContext.IsSecondFunction"/>
                                </MultiBinding>
                            </Button.Content>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Viewbox>
</UserControl>
