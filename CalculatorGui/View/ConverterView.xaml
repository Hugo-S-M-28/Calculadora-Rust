<UserControl x:Class="CalculatorGui.View.ConverterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CalculatorGui.View"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="1" Width="350" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10,0">
            <!-- Category Section -->
            <TextBlock Text="Categoría" Foreground="{DynamicResource TextSecBrush}" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox x:Name="CboCategory" 
                      Height="35" 
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Background="{DynamicResource ScreenBgBrush}" 
                      Foreground="{DynamicResource TextMainBrush}" 
                      BorderBrush="{DynamicResource BorderBrush}" 
                      Margin="0,0,0,15"/>

            <!-- From Section -->
            <TextBlock Text="De" Foreground="{DynamicResource TextSecBrush}" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox x:Name="CboFromUnit" 
                      Height="35" 
                      ItemsSource="{Binding Units}"
                      SelectedItem="{Binding SelectedFromUnit, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Background="{DynamicResource ScreenBgBrush}" 
                      Foreground="{DynamicResource TextMainBrush}" 
                      BorderBrush="{DynamicResource BorderBrush}" 
                      Margin="0,0,0,10"/>
            
            <TextBox x:Name="TxtFromValue" 
                     Height="45" 
                     Text="{Binding FromValue, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                     FontSize="20" 
                     FontFamily="Consolas, Segoe UI"
                     Background="{DynamicResource ScreenBgBrush}" 
                     Foreground="{DynamicResource TextMainBrush}" 
                     BorderBrush="{DynamicResource BorderBrush}" 
                     BorderThickness="1" 
                     Padding="10,5" 
                     Margin="0,0,0,20"/>

            <!-- Direction Arrow -->
            <TextBlock Text="➜" 
                       FontSize="22" 
                       Foreground="{DynamicResource SciButtonTextBrush}" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <!-- To Section -->
            <TextBlock Text="A" Foreground="{DynamicResource TextSecBrush}" FontSize="12" Margin="0,0,0,5"/>
            <ComboBox x:Name="CboToUnit" 
                      Height="35" 
                      ItemsSource="{Binding Units}"
                      SelectedItem="{Binding SelectedToUnit, Mode=TwoWay}"
                      DisplayMemberPath="Name"
                      Background="{DynamicResource ScreenBgBrush}" 
                      Foreground="{DynamicResource TextMainBrush}" 
                      BorderBrush="{DynamicResource BorderBrush}" 
                      Margin="0,0,0,10"/>

            <!-- Converted Value Output -->
            <Border Background="{DynamicResource ScreenBgBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Height="65" 
                    Padding="15,10">
                <TextBlock x:Name="TxtToValue" 
                           Text="{Binding ToValue}" 
                           FontSize="28" 
                           FontWeight="Bold" 
                           FontFamily="Consolas, Segoe UI"
                           Foreground="{DynamicResource SciButtonTextBrush}" 
                           VerticalAlignment="Center"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
