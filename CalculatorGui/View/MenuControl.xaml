<UserControl x:Class="CalculatorGui.MenuControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CalculatorGui"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="220">
    <Border Background="{DynamicResource SidebarBgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,1,0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Sidebar Title / Back Button -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="15,15,15,20">
                <Button Content="☰" 
                        Width="36" Height="36" 
                        Style="{StaticResource ThemeToggleButtonStyle}"
                        Click="BtnMenuToggle_Click"
                        Margin="0,0,10,0"/>
                <TextBlock Text="Calculadora" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextMainBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Navigation Links -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="10,0">
                    <!-- Section: Calculadora -->
                    <TextBlock Text="Calculadora" Foreground="{DynamicResource TextSecBrush}" FontSize="12" FontWeight="Bold" Margin="10,0,0,5"/>
                    <Button Content="Estándar" Tag="Standard" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                    <Button Content="Científica" Tag="Scientific" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                    <Button Content="Graficar" Tag="Graphing" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>

                    <!-- Section: Conversor -->
                    <TextBlock Text="Conversor" Foreground="{DynamicResource TextSecBrush}" FontSize="12" FontWeight="Bold" Margin="10,20,0,5"/>
                    <Button Content="Conversor de Unidades" Tag="Converter" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
