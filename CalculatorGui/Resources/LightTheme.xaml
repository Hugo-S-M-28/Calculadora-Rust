<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Fluent Light Theme Brushes -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="ScreenBgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="#EAEAEA"/>
    <SolidColorBrush x:Key="TextMainBrush" Color="#1C1C1C"/>
    <SolidColorBrush x:Key="TextSecBrush" Color="#5F5F5F"/>
    
    <!-- Button Colors -->
    <SolidColorBrush x:Key="ButtonBgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ButtonHoverBgBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="SciButtonBgBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="SciButtonTextBrush" Color="#0067C0"/>
    <SolidColorBrush x:Key="OpButtonBgBrush" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="OpButtonTextBrush" Color="#7A24CF"/>
    <SolidColorBrush x:Key="ActionTextBrush" Color="#C41C3B"/>
    <SolidColorBrush x:Key="ActionBgBrush" Color="#FDF0F2"/>
    <SolidColorBrush x:Key="ActionHoverBgBrush" Color="#FADCE1"/>
    
    <!-- Accents & Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="HeaderBorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>
    
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0067C0" Offset="0"/>
        <GradientStop Color="#7A24CF" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
