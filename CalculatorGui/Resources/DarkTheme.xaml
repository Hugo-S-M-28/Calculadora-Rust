<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Fluent Dark Theme Brushes -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="#202020"/>
    <SolidColorBrush x:Key="ScreenBgBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="SidebarBgBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TextMainBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecBrush" Color="#A0A0A0"/>
    
    <!-- Button Colors -->
    <SolidColorBrush x:Key="ButtonBgBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="ButtonHoverBgBrush" Color="#3D3D3D"/>
    <SolidColorBrush x:Key="SciButtonBgBrush" Color="#323232"/>
    <SolidColorBrush x:Key="SciButtonTextBrush" Color="#60CDFF"/>
    <SolidColorBrush x:Key="OpButtonBgBrush" Color="#383838"/>
    <SolidColorBrush x:Key="OpButtonTextBrush" Color="#B154FC"/>
    <SolidColorBrush x:Key="ActionTextBrush" Color="#FF6B8B"/>
    <SolidColorBrush x:Key="ActionBgBrush" Color="#3E2A30"/>
    <SolidColorBrush x:Key="ActionHoverBgBrush" Color="#51363E"/>
    
    <!-- Accents & Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="HeaderBorderBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF"/>
    
    <LinearGradientBrush x:Key="AccentBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#00F2FE" Offset="0"/>
        <GradientStop Color="#A15DFC" Offset="1"/>
    </LinearGradientBrush>

</ResourceDictionary>
